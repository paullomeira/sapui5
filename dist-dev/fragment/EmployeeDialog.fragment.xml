<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f">
    
    <Dialog
        id="employeeDialog"
        title="{i18n>dialog.employee.title}"
        contentWidth="400px"
        contentHeight="500px"
        resizable="true"
        draggable="true"
        afterClose="onEmployeeDialogClose"
        class="customDialog">
        
        <content>
            <VBox class="customPaddingMedium">
                
                <!-- Employee Header Info -->
                <f:Card class="sapUiMediumMarginBottom">
                    <f:header>
                        <f:CardHeader
                            title="{employee>/firstName} {employee>/lastName}"
                            subtitle="{employee>/position}"
                            iconSrc="sap-icon://person-placeholder" />
                    </f:header>
                    <f:content>
                        <VBox class="sapUiSmallMargin">
                            <HBox>
                                <Label text="{i18n>label.email}:" class="sapUiTinyMarginEnd" width="80px"/>
                                <Text text="{employee>/email}" />
                            </HBox>
                            <HBox class="sapUiTinyMarginTop">
                                <Label text="{i18n>label.department}:" class="sapUiTinyMarginEnd" width="80px"/>
                                <Text text="{employee>/department}" />
                            </HBox>
                            <HBox class="sapUiTinyMarginTop">
                                <Label text="{i18n>label.status}:" class="sapUiTinyMarginEnd" width="80px"/>
                                <ObjectStatus 
                                    text="{employee>/status}"
                                    state="{
                                        path: 'employee>/status',
                                        formatter: '.formatStatusState'
                                    }" />
                            </HBox>
                        </VBox>
                    </f:content>
                </f:Card>
                
                <!-- Quick Actions -->
                <VBox>
                    <Title text="{i18n>dialog.quickActions}" class="sapUiMediumMarginBottom" />
                    
                    <!-- Status Change -->
                    <HBox class="sapUiTinyMarginBottom" alignItems="Center">
                        <Label text="{i18n>label.changeStatus}:" class="sapUiTinyMarginEnd" width="120px"/>
                        <Select
                            id="statusSelect"
                            selectedKey="{employee>/status}"
                            width="150px"
                            change="onStatusChange">
                            <core:Item key="Active" text="{i18n>status.active}" />
                            <core:Item key="Inactive" text="{i18n>status.inactive}" />
                            <core:Item key="On Leave" text="{i18n>status.onLeave}" />
                        </Select>
                    </HBox>
                    
                    <!-- Department Change -->
                    <HBox class="sapUiTinyMarginBottom" alignItems="Center">
                        <Label text="{i18n>label.changeDepartment}:" class="sapUiTinyMarginEnd" width="120px"/>
                        <Select
                            id="departmentSelect"
                            selectedKey="{employee>/department}"
                            width="150px"
                            change="onDepartmentChange"
                            items="{/departments}">
                            <core:Item key="{key}" text="{text}" />
                        </Select>
                    </HBox>
                    
                    <!-- Salary Update -->
                    <HBox class="sapUiTinyMarginBottom" alignItems="Center">
                        <Label text="{i18n>label.salary}:" class="sapUiTinyMarginEnd" width="120px"/>
                        <Input
                            id="salaryInput"
                            value="{employee>/salary}"
                            type="Number"
                            width="150px"
                            change="onSalaryChange" />
                    </HBox>
                </VBox>
                
                <!-- Action History (placeholder) -->
                <VBox class="sapUiMediumMarginTop">
                    <Title text="{i18n>dialog.recentActions}" class="sapUiMediumMarginBottom" />
                    <List
                        id="actionHistoryList"
                        noDataText="{i18n>msg.noRecentActions}"
                        items="{employee>/actionHistory}">
                        <StandardListItem
                            title="{action}"
                            description="{date}"
                            icon="sap-icon://history" />
                    </List>
                </VBox>
                
            </VBox>
        </content>
        
        <buttons>
            <Button
                text="{i18n>btn.save}"
                type="Emphasized"
                press="onSaveEmployeeChanges" />
            <Button
                text="{i18n>btn.edit}"
                press="onEditEmployee" />
            <Button
                text="{i18n>btn.close}"
                press="onCloseEmployeeDialog" />
        </buttons>
        
    </Dialog>
    
</core:FragmentDefinition>