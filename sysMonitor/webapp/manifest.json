{
  "_version": "1.32.0",
  "sap.app": {
    "id": "com.systemmonitor",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "sap-icon://alert",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    },
    "supportedThemes": ["sap_horizon"]
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "com.systemmonitor.view.App",
      "type": "XML",
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.ui.core": {},
        "sap.m": {},
        "sap.ui.layout": {}
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.systemmonitor.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "transition": "slide"
      },
      "routes": [
        { "name": "overview", "pattern": "", "target": "overview" },
        { "name": "logs", "pattern": "logs", "target": "logs" },
        { "name": "system", "pattern": "system/{systemId}", "target": "system" },
        { "name": "settings", "pattern": "settings", "target": "settings" }
      ],
      "targets": {
        "overview": { "viewName": "Overview", "viewId": "overview" },
        "logs": { "viewName": "Logs", "viewId": "logs" },
        "system": { "viewName": "SystemDetail", "viewId": "system" },
        "settings": { "viewName": "Settings", "viewId": "settings" }
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "com.systemmonitor.i18n.i18n" }
      },
      "": { "type": "sap.ui.model.json.JSONModel" }
    }
  }
}
